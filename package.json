{
  "name": "picnest-image-host",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"node server/index.js\" \"vite --host 127.0.0.1\"",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc -b --pretty false",
    "test": "node --test --test-concurrency=1",
    "test:ui": "npm run build && node scripts/preflight-ui.mjs",
    "build": "tsc -b && vite build",
    "check": "npm run lint && npm run typecheck && npm test && npm run build",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1086.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "cookie-parser": "^1.4.7",
    "exifr": "^7.1.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.3.0",
    "image-size": "^2.0.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.468.0",
    "multer": "^2.0.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.2.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "playwright-core": "^1.61.1",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^6.0.5"
  }
}
