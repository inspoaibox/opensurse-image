# Generate with: openssl rand -hex 48
PICNEST_SESSION_SECRET=replace-with-a-long-random-secret

# Set true only when the public site is served over HTTPS.
COOKIE_SECURE=true

# Optional. Defaults to /opt/picnest/server/data/picnest.db in this layout.
PICNEST_DB_PATH=/opt/picnest/server/data/picnest.db
