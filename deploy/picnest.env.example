# Generate with: openssl rand -hex 48
PICNEST_SESSION_SECRET=replace-with-a-long-random-secret

# Express listens on 127.0.0.1 only. Keep the reverse proxy upstream in sync.
PORT=18765

# Encrypts cloud and WebDAV credentials in SQLite. Generate and back up separately.
# Never change this value after adding a storage provider.
PICNEST_STORAGE_SECRET=replace-with-another-long-random-secret

# Set true only when the public site is served over HTTPS.
COOKIE_SECURE=true

# Optional. Defaults to /opt/picnest/server/data/picnest.db in this layout.
PICNEST_DB_PATH=/opt/picnest/server/data/picnest.db

# Optional monthly API-key call limit. Requests over the limit receive HTTP 429.
PICNEST_API_MONTHLY_LIMIT=50000

# Public origin used in API image URLs behind Nginx or Caddy. No trailing slash.
PICNEST_PUBLIC_URL=https://img.example.com
